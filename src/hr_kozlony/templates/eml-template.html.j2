<!doctype html>
<html lang="hu">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HR Középvállalati Havi Riport — {{ run_date }}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; max-width: 760px; margin: 24px auto; padding: 0 16px; color: #1a1a1a; line-height: 1.55; background: #ffffff;">

<h1 style="font-size: 22px; color: #0b3d91; border-bottom: 3px solid #0b3d91; padding-bottom: 6px; margin: 0 0 4px 0;">HR Középvállalati — Magyar Közlöny Havi Riport</h1>
<div style="color: #555; font-size: 13px; margin: 0 0 24px 0;">
  Futtatás dátuma: <strong style="color: #1a1a1a;">{{ run_date }}</strong> &middot;
  Lookback: <strong style="color: #1a1a1a;">{{ lookback_start }} &rarr; {{ lookback_end }}</strong> &middot;
  Feldolgozott lapszámok: <strong style="color: #1a1a1a;">{{ issues_scanned }}</strong> &middot;
  Új változások: <strong style="color: #1a1a1a;">{{ new_items_count }}</strong>
</div>

{% if new_items_count == 0 %}
  <div style="background: #fff7e6; border: 1px solid #f5d28a; border-radius: 6px; padding: 14px 16px; color: #6a4a00; margin: 12px 0;">
    Ebben a futásban nem találtam új, a HR területét (munkajog, bér, juttatás, foglalkoztatás, munkavédelem) érintő bekezdést a Magyar Közlönyben.
    A figyelt időablak: {{ lookback_start }} &ndash; {{ lookback_end }}.
  </div>
{% else %}
  {% for issue in grouped_issues %}
    <h2 style="font-size: 17px; color: #0b3d91; margin: 28px 0 4px 0; padding: 6px 10px; background: #f0f4fa; border-left: 4px solid #0b3d91;">
      {% set issue_name = issue.number %}{% if not issue.number.startswith("Magyar Közlöny") %}Magyar Közlöny {{ issue.number }}{% else %}{{ issue.number }}{% endif %}<span style="color: #777; font-weight: normal; font-size: 13px; margin-left: 8px;">{{ issue.date }}</span>
    </h2>
    {% if issue.url %}<div style="font-size: 12px; color: #555; margin: 0 0 8px 0;">Ezen a linken éred el ezt a közlönyt: <a style="color: #0b3d91;" href="{{ issue.url }}">{{ issue.url }}</a></div>{% endif %}
    {% for item in issue["items"] %}
      <div style="border: 1px solid #e3e8f0; border-radius: 6px; padding: 12px 14px; margin: 12px 0; background: #fafcff;">
        <h3 style="font-size: 15px; margin: 0 0 6px 0; color: #1a1a1a;">
          <span style="color: #0b3d91; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; margin-right: 6px;">&sect; {{ item.anchor }}</span>{{ item.one_line_summary_hu }}
        </h3>
        <div style="font-size: 12px; color: #666; margin: 0 0 8px 0;">
          <span style="color: #0a6b3a; font-weight: 600;">Relevancia: {{ "%.2f"|format(item.score) }}</span>
          &middot;
          {% for t in item.matched_topics %}<span style="display: inline-block; background: #e8eef9; color: #0b3d91; padding: 1px 7px; border-radius: 10px; margin-right: 4px; font-weight: 500;">{{ t }}</span>{% endfor %}
        </div>
        <div style="font-size: 14px; margin: 6px 0 8px 0;">{{ item.expansion_hu }}</div>
        {% if item.key_dates_hu %}
          <div style="font-size: 12px; color: #555; margin: 4px 0;"><strong style="color: #1a1a1a;">Határidők:</strong> {{ item.key_dates_hu | join(" &middot; ") }}</div>
        {% endif %}
        {% if item.action_items_hu %}
          <ul style="font-size: 13px; margin: 6px 0 0 0; padding-left: 18px;">
            {% for a in item.action_items_hu %}<li style="margin: 3px 0;">{{ a }}</li>{% endfor %}
          </ul>
        {% endif %}
        {% if item.indokolas_url %}
          <a style="display: inline-block; margin-top: 6px; font-size: 12px; color: #0b3d91; text-decoration: none;" href="{{ item.indokolas_url }}">📄 Indokolás megnyitása</a>
        {% endif %}
      </div>
    {% endfor %}
  {% endfor %}
{% endif %}

<div style="margin-top: 36px; padding-top: 12px; border-top: 1px solid #e3e8f0; font-size: 11px; color: #888;">
  Automatikusan generálva &middot; Forrás: <a style="color: #0b3d91;" href="https://magyarkozlony.hu">magyarkozlony.hu</a> &middot;
  Szűrési küszöb: relevancia &ge; {{ "%.2f"|format(relevance_threshold) }} (tág) &middot;
  Témakör: HR középvállalati (~200 fő)
</div>

</body>
</html>

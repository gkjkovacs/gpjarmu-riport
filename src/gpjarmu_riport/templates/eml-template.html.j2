<!doctype html>
<html lang="hu">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Céges Gépjármű Havi Riport — {{ run_date }}</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      max-width: 760px;
      margin: 24px auto;
      padding: 0 16px;
      color: #1a1a1a;
      line-height: 1.55;
      background: #ffffff;
    }
    h1 {
      font-size: 22px;
      color: #0b3d91;
      border-bottom: 3px solid #0b3d91;
      padding-bottom: 6px;
      margin-bottom: 4px;
    }
    .meta {
      color: #555;
      font-size: 13px;
      margin-bottom: 24px;
    }
    h2 {
      font-size: 17px;
      color: #0b3d91;
      margin-top: 28px;
      margin-bottom: 4px;
      padding: 6px 10px;
      background: #f0f4fa;
      border-left: 4px solid #0b3d91;
    }
    h2 .date {
      color: #777;
      font-weight: normal;
      font-size: 13px;
      margin-left: 8px;
    }
    .item {
      border: 1px solid #e3e8f0;
      border-radius: 6px;
      padding: 12px 14px;
      margin: 12px 0;
      background: #fafcff;
    }
    .item h3 {
      font-size: 15px;
      margin: 0 0 6px 0;
      color: #1a1a1a;
    }
    .item h3 .anchor {
      color: #0b3d91;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 13px;
      margin-right: 6px;
    }
    .strip {
      font-size: 12px;
      color: #666;
      margin-bottom: 8px;
    }
    .strip .badge {
      display: inline-block;
      background: #e8eef9;
      color: #0b3d91;
      padding: 1px 7px;
      border-radius: 10px;
      margin-right: 4px;
      font-weight: 500;
    }
    .strip .score {
      color: #0a6b3a;
      font-weight: 600;
    }
    .expansion {
      font-size: 14px;
      margin: 6px 0 8px 0;
    }
    .dates {
      font-size: 12px;
      color: #555;
      margin: 4px 0;
    }
    .dates strong { color: #1a1a1a; }
    .actions {
      font-size: 13px;
      margin: 6px 0 0 0;
      padding-left: 18px;
    }
    .actions li { margin: 3px 0; }
    .indokolas {
      display: inline-block;
      margin-top: 6px;
      font-size: 12px;
      color: #0b3d91;
      text-decoration: none;
    }
    .indokolas:hover { text-decoration: underline; }
    .empty {
      background: #fff7e6;
      border: 1px solid #f5d28a;
      border-radius: 6px;
      padding: 14px 16px;
      color: #6a4a00;
    }
    .footer {
      margin-top: 36px;
      padding-top: 12px;
      border-top: 1px solid #e3e8f0;
      font-size: 11px;
      color: #888;
    }
  </style>
</head>
<body>

<h1>Céges Gépjármű — Magyar Közlöny Havi Riport</h1>
<div class="meta">
  Futtatás dátuma: <strong>{{ run_date }}</strong> ·
  Lookback: <strong>{{ lookback_start }} → {{ lookback_end }}</strong> ·
  Feldolgozott lapszámok: <strong>{{ issues_scanned }}</strong> ·
  Új változások: <strong>{{ new_items_count }}</strong>
</div>

{% if new_items_count == 0 %}
  <div class="empty">
    Ebben a futásban nem találtam új, a céges gépjármű-témakört érintő bekezdést a Magyar Közlönyben.
    A figyelt időablak: {{ lookback_start }} – {{ lookback_end }}.
  </div>
{% else %}
  {% for issue in grouped_issues %}
    <h2>
      Magyar Közlöny {{ issue.number }}<span class="date">{{ issue.date }}</span>
    </h2>
    {% for item in issue["items"] %}
      <div class="item">
        <h3><span class="anchor">§ {{ item.anchor }}</span>{{ item.one_line_summary_hu }}</h3>
        <div class="strip">
          <span class="score">Relevancia: {{ "%.2f"|format(item.score) }}</span>
          ·
          {% for t in item.matched_topics %}<span class="badge">{{ t }}</span>{% endfor %}
        </div>
        <div class="expansion">{{ item.expansion_hu }}</div>
        {% if item.key_dates_hu %}
          <div class="dates"><strong>Határidők:</strong> {{ item.key_dates_hu | join(" · ") }}</div>
        {% endif %}
        {% if item.action_items_hu %}
          <ul class="actions">
            {% for a in item.action_items_hu %}<li>{{ a }}</li>{% endfor %}
          </ul>
        {% endif %}
        {% if item.indokolas_url %}
          <a class="indokolas" href="{{ item.indokolas_url }}">📄 Indokolás megnyitása</a>
        {% endif %}
      </div>
    {% endfor %}
  {% endfor %}
{% endif %}

<div class="footer">
  Automatikusan generálva · Forrás: <a href="https://magyarkozlony.hu">magyarkozlony.hu</a> ·
  Szűrési küszöb: relevancia ≥ {{ "%.2f"|format(relevance_threshold) }} (tág) ·
  Témakör: Gépjármű / Céges Gépjármű
</div>

</body>
</html>

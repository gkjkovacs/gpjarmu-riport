# =============================================================================
# Vercel runtime — environment variables
# =============================================================================
# Set these in the Vercel project UI: Settings → Environment Variables.
# The placeholders below MUST be replaced with real values before deploy.
# =============================================================================

# --- Auth (required) ---
# A long random secret. The SaaS (magyar_kozlony) will send this in
# `Authorization: Bearer ***` on every request to /runs, /scopes, /scopes/{name}.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RUNTIME_TOKEN=__REPLACE_ME_RUNTIME_TOKEN__

# --- LLM (required) ---
# Provider. OPENAI works for any OpenAI-compatible endpoint (Ollama Cloud, etc.).
LLM_PROVIDER=openai
LLM_BASE_URL=https://ollama.com/v1
# Get your key at https://ollama.com/settings (or your provider's dashboard).
OLLAMA_API_KEY=__REPLACE_ME_OLLAMA_API_KEY__
# Model name. For Ollama Cloud use the `:cloud` suffix.
OLLAMA_MODEL=minimax-m3:cloud

# --- Pipeline defaults (overridable per request via POST /runs payload) ---
SCOPE=konyveles
LOOKBACK_DAYS=30
RELEVANCE_THRESHOLD=0.50
MAX_ISSUES_PER_RUN=50
CLASSIFY_CONCURRENCY=5
KEYWORD_FILTER_ENABLED=true

# --- LLM call budget (per pipeline run) ---
# Caps how many LLM calls classify / expand can make in a single run.
LLM_BUDGET_CLASSIFY=300
LLM_BUDGET_EXPAND=20

# --- State / output paths ---
# On Vercel these are forced to /tmp by api/index.py (read-only filesystem).
# For local dev, leave them as the defaults below.
STATE_DB_PATH=./data/state.db
OUTPUT_DIR=./output
LOG_FILE=./data/run.log

# --- Email (optional; SMTP_ENABLED=false disables email sending) ---
SMTP_ENABLED=false
EMAIL_FROM=hr-kozlony@localhost
EMAIL_TO=you@example.com
EMAIL_SUBJECT_PREFIX=[HR riport]
SMTP_HOST=smtp.freemail.hu
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=__REPLACE_ME_SMTP_USER__
SMTP_PASSWORD=__REPLACE_ME_SMTP_PASSWORD__

# --- Misc ---
LOG_LEVEL=INFO
DRY_RUN=false
LLM_DEBUG=false
PYTHONUNBUFFERED=1

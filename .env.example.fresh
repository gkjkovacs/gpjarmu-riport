# =============================================================================
# Céges Gépjármű Magyar Közlöny Havi Riport — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider (OpenAI-compatible API)
# -----------------------------------------------------------------------------
# Default uses Ollama Cloud with the same model the Hermes Agent uses
# (minimax-m3:cloud, US-based, zero data retention).
# Override LLM_BASE_URL to use a local Ollama (http://localhost:11434/v1)
# or any other OpenAI-compatible endpoint (LM Studio, OpenRouter, Azure, etc.).

LLM_PROVIDER=openai
LLM_BASE_URL=https://ollama.com/v1
# IMPORTANT: replace with your real Ollama Cloud API key from https://ollama.com/settings
LLM_API_KEY=REPLACE_ME_WITH_OLLAMA_CLOUD_API_KEY

# Model name (use `:cloud` suffix for Ollama Cloud, plain name for local Ollama)
LLM_MODEL=minimax-m3:cloud

# LLM generation parameters
LLM_TEMPERATURE_CLASSIFY=0.0
LLM_TEMPERATURE_EXPAND=0.2
LLM_MAX_TOKENS_CLASSIFY=512
LLM_MAX_TOKENS_EXPAND=1024
# Request timeout for LLM calls (seconds)
LLM_TIMEOUT=120

# -----------------------------------------------------------------------------
# Monitor configuration
# -----------------------------------------------------------------------------
# Lookback window in days (rolling, applied backward from run date)
LOOKBACK_DAYS=30

# Relevance threshold (0.00–1.00). tág (broad) = 0.50, szűk (narrow) = 0.75
RELEVANCE_THRESHOLD=0.50

# Magyar Közlöny base URL
KOZLONY_BASE_URL=https://magyarkozlony.hu

# Number of issues to fetch per scrape run (cap, prevents runaway)
MAX_ISSUES_PER_RUN=50

# Drop bekezdések shorter than this many characters (filters out page footers etc.)
MIN_BEKezdes_LENGTH=30

# HTTP request timeout for scraper (seconds)
SCRAPER_TIMEOUT=30

# User-Agent header for scraper (government sites sometimes block default UAs)
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) GpjarmuRiport/1.0

# -----------------------------------------------------------------------------
# State database
# -----------------------------------------------------------------------------
# Path to the SQLite state DB. Relative to project root, or absolute.
STATE_DB_PATH=./data/state.db

# -----------------------------------------------------------------------------
# Output (.eml file)
# -----------------------------------------------------------------------------
# Where to write the .eml file
OUTPUT_DIR=./output

# From / To headers (used as envelope sender / recipient when SMTP is enabled)
# For freemail.hu, EMAIL_FROM must match the SMTP_USERNAME address, otherwise
# the SMTP server rejects the message.
EMAIL_FROM=gergely.kovacs@freemail.hu
EMAIL_TO=peter.szekely@jafholz.hu

# Subject prefix (final subject is: "<prefix> YYYY-MM-DD – N új változás")
EMAIL_SUBJECT_PREFIX=[Céges Gépjármű riport]

# -----------------------------------------------------------------------------
# SMTP (freemail.hu — verified working from this sandbox on 2026-07-14)
# -----------------------------------------------------------------------------
# Set SMTP_ENABLED=true to ship the .txt report by email after each run.
# freemail.hu SMTP settings (per https://accounts.freemail.hu/a/help/faq/clients):
#   Host:     smtp.freemail.hu
#   Port:     587 (STARTTLS, recommended) or 465 (SSL)
#   Username: your FULL email address (e.g. gergely.kovacs@freemail.hu)
#   Password: the same password you log in with at https://accounts.freemail.hu
SMTP_ENABLED=true
SMTP_HOST=smtp.freemail.hu
SMTP_PORT=587
# Security: starttls (port 587) | ssl (port 465) | none (NOT recommended)
SMTP_SECURITY=starttls
# MUST be the full freemail address, not just the local part.
SMTP_USERNAME=gergely.kovacs@freemail.hu
# REPLACE with your real freemail webmail password. If it contains special
# characters (!, #, &, etc.) wrap the value in double quotes.
SMTP_PASSWORD=REPLACE_ME_WITH_YOUR_FREEMAIL_PASSWORD
# true = .txt attached + short cover message; false = full report in body
SMTP_ATTACHMENT=true
# Timeout (seconds) for the SMTP connection
SMTP_TIMEOUT=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./data/run.log

# -----------------------------------------------------------------------------
# Development / debug
# -----------------------------------------------------------------------------
# Dry run: do everything except the SMTP send / .eml write
DRY_RUN=false
# Verbose LLM logging
LLM_DEBUG=false
